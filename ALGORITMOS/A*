      "source": [
        "import heapq\n",
        "import matplotlib.pyplot as plt\n",
        "import time\n",
        "from IPython.display import clear_output\n",
        "\n",
        "# =========================\n",
        "# CONFIGURACIÓN\n",
        "# =========================\n",
        "\n",
        "N = 8\n",
        "\n",
        "inicio = (2, 0)\n",
        "objetivo = (4, 7)\n",
        "\n",
        "obstaculos = {\n",
        "    (1,3),(1,4),(1,5),\n",
        "    (2,3),\n",
        "    (3,1),(3,2),(3,3),\n",
        "    (5,5),(6,5)\n",
        "}\n",
        "\n",
        "# =========================\n",
        "# HEURÍSTICA Manhattan\n",
        "# =========================\n",
        "def h(a, b):\n",
        "    return abs(a[0]-b[0]) + abs(a[1]-b[1])\n",
        "\n",
        "# =========================\n",
        "# DIBUJAR TABLERO\n",
        "# =========================\n",
        "def dibujar(camino=None, explorados=None, orden=None):\n",
        "\n",
        "    clear_output(wait=True)\n",
        "    fig, ax = plt.subplots(figsize=(6,6))\n",
        "\n",
        "    # cuadrícula\n",
        "    for x in range(N+1):\n",
        "        ax.plot([0,N],[x,x], color=\"black\")\n",
        "        ax.plot([x,x],[0,N], color=\"black\")\n",
        "\n",
        "    # obstáculos\n",
        "    for r,c in obstaculos:\n",
        "        ax.add_patch(plt.Rectangle((c, N-1-r),1,1,color=\"black\"))\n",
        "\n",
        "    # nodos explorados con número\n",
        "    if explorados:\n",
        "        for (r,c) in explorados:\n",
        "            ax.plot(c+0.5, N-1-r+0.5, 'o', color='blue')\n",
        "\n",
        "            if orden and (r,c) in orden:\n",
        "                ax.text(c+0.5, N-1-r+0.5,\n",
        "                        str(orden[(r,c)]),\n",
        "                        ha='center', va='center',\n",
        "                        color='white', fontsize=10)\n",
        "\n",
        "    # camino final con flechas\n",
        "    if camino:\n",
        "        for i in range(len(camino)-1):\n",
        "            r1,c1 = camino[i]\n",
        "            r2,c2 = camino[i+1]\n",
        "\n",
        "            ax.arrow(c1+0.5, N-1-r1+0.5,\n",
        "                     c2-c1, -(r2-r1),\n",
        "                     head_width=0.15,\n",
        "                     length_includes_head=True,\n",
        "                     color='orange',\n",
        "                     linewidth=2)\n",
        "\n",
        "    # inicio\n",
        "    r,c = inicio\n",
        "    ax.add_patch(plt.Rectangle((c, N-1-r),1,1,color=\"red\"))\n",
        "    ax.text(c+0.5, N-1-r+0.5, \"A\",\n",
        "            ha='center', va='center',\n",
        "            color='white', fontsize=14, weight='bold')\n",
        "\n",
        "    # objetivo\n",
        "    r,c = objetivo\n",
        "    ax.add_patch(plt.Rectangle((c, N-1-r),1,1,color=\"green\"))\n",
        "    ax.text(c+0.5, N-1-r+0.5, \"B\",\n",
        "            ha='center', va='center',\n",
        "            color='white', fontsize=14, weight='bold')\n",
        "\n",
        "    ax.set_xlim(0,N)\n",
        "    ax.set_ylim(0,N)\n",
        "    ax.set_aspect('equal')\n",
        "    ax.axis('off')\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# =========================\n",
        "# A* CON NUMERACIÓN\n",
        "# =========================\n",
        "def a_star():\n",
        "\n",
        "    abiertos = []\n",
        "    heapq.heappush(abiertos, (0, inicio))\n",
        "\n",
        "    vino_de = {}\n",
        "    g = {inicio: 0}\n",
        "\n",
        "    explorados = []\n",
        "    orden = {}\n",
        "    contador = 1\n",
        "\n",
        "    while abiertos:\n",
        "\n",
        "        _, actual = heapq.heappop(abiertos)\n",
        "\n",
        "        if actual == objetivo:\n",
        "\n",
        "            camino = []\n",
        "            while actual in vino_de:\n",
        "                camino.append(actual)\n",
        "                actual = vino_de[actual]\n",
        "            camino.append(inicio)\n",
        "            camino.reverse()\n",
        "\n",
        "            dibujar(camino, explorados, orden)\n",
        "            return camino\n",
        "\n",
        "        explorados.append(actual)\n",
        "        orden[actual] = contador\n",
        "        contador += 1\n",
        "\n",
        "        dibujar(None, explorados, orden)\n",
        "        time.sleep(1)\n",
        "\n",
        "        r,c = actual\n",
        "\n",
        "        vecinos = [(r+1,c),(r-1,c),(r,c+1),(r,c-1)]\n",
        "\n",
        "        for nr,nc in vecinos:\n",
        "\n",
        "            if not (0 <= nr < N and 0 <= nc < N):\n",
        "                continue\n",
        "\n",
        "            if (nr,nc) in obstaculos:\n",
        "                continue\n",
        "\n",
        "            nuevo_g = g[actual] + 1\n",
        "\n",
        "            if (nr,nc) not in g or nuevo_g < g[(nr,nc)]:\n",
        "\n",
        "                g[(nr,nc)] = nuevo_g\n",
        "                f = nuevo_g + h((nr,nc), objetivo)\n",
        "\n",
        "                heapq.heappush(abiertos, (f, (nr,nc)))\n",
        "                vino_de[(nr,nc)] = actual\n",
        "\n",
        "    return None\n",
        "\n",
        "\n",
        "# =========================\n",
        "# EJECUTAR\n",
        "# =========================\n",
        "\n",
        "camino = a_star()\n",
        "\n",
        "print(\"⭐ Camino encontrado:\")\n",
        "print(camino)"
      ],
