        "import heapq\n",
        "import matplotlib.pyplot as plt\n",
        "import time\n",
        "from IPython.display import clear_output\n",
        "\n",
        "# =========================\n",
        "# MAPA (tipo GPS)\n",
        "# =========================\n",
        "\n",
        "N = 10\n",
        "\n",
        "inicio = (0, 0)\n",
        "objetivo = (9, 9)\n",
        "\n",
        "obstaculos = {\n",
        "    (1,3),(2,3),(3,3),(4,3),(5,3),\n",
        "    (5,4),(5,5),(5,6),\n",
        "    (2,7),(3,7),(4,7),(5,7)\n",
        "}\n",
        "\n",
        "# =========================\n",
        "# HEURÍSTICA\n",
        "# =========================\n",
        "\n",
        "def h(a, b):\n",
        "    return abs(a[0]-b[0]) + abs(a[1]-b[1])\n",
        "\n",
        "\n",
        "# =========================\n",
        "# ALGORITMO A*\n",
        "# =========================\n",
        "\n",
        "def a_star():\n",
        "\n",
        "    abiertos = []\n",
        "    heapq.heappush(abiertos, (0, inicio))\n",
        "\n",
        "    vino_de = {}\n",
        "    g = {inicio: 0}\n",
        "\n",
        "    while abiertos:\n",
        "\n",
        "        _, actual = heapq.heappop(abiertos)\n",
        "\n",
        "        if actual == objetivo:\n",
        "\n",
        "            camino = []\n",
        "            while actual in vino_de:\n",
        "                camino.append(actual)\n",
        "                actual = vino_de[actual]\n",
        "            camino.append(inicio)\n",
        "            camino.reverse()\n",
        "            return camino\n",
        "\n",
        "        r, c = actual\n",
        "\n",
        "        vecinos = [(r+1,c),(r-1,c),(r,c+1),(r,c-1)]\n",
        "\n",
        "        for nr, nc in vecinos:\n",
        "\n",
        "            if not (0 <= nr < N and 0 <= nc < N):\n",
        "                continue\n",
        "\n",
        "            if (nr, nc) in obstaculos:\n",
        "                continue\n",
        "\n",
        "            nuevo_g = g[actual] + 1\n",
        "\n",
        "            if (nr, nc) not in g or nuevo_g < g[(nr, nc)]:\n",
        "\n",
        "                g[(nr, nc)] = nuevo_g\n",
        "                f = nuevo_g + h((nr, nc), objetivo)\n",
        "\n",
        "                heapq.heappush(abiertos, (f, (nr, nc)))\n",
        "                vino_de[(nr, nc)] = actual\n",
        "\n",
        "    return None\n",
        "\n",
        "\n",
        "# =========================\n",
        "# DIBUJAR PASO A PASO\n",
        "# =========================\n",
        "\n",
        "def dibujar_parcial(camino_hasta_ahora):\n",
        "\n",
        "    clear_output(wait=True)\n",
        "    fig, ax = plt.subplots(figsize=(6,6))\n",
        "\n",
        "    # cuadrícula\n",
        "    for x in range(N+1):\n",
        "        ax.plot([0,N],[x,x], color=\"gray\")\n",
        "        ax.plot([x,x],[0,N], color=\"gray\")\n",
        "\n",
        "    # obstáculos\n",
        "    for r,c in obstaculos:\n",
        "        ax.add_patch(plt.Rectangle((c, N-1-r),1,1,color=\"black\"))\n",
        "\n",
        "    # dibujar recorrido parcial\n",
        "    for i, (r,c) in enumerate(camino_hasta_ahora):\n",
        "\n",
        "        # número del paso\n",
        "        ax.text(c+0.5, N-1-r+0.5,\n",
        "                str(i),\n",
        "                ha='center', va='center',\n",
        "                color='blue',\n",
        "                fontsize=14,\n",
        "                weight='bold')\n",
        "\n",
        "        # flecha hacia el siguiente\n",
        "        if i < len(camino_hasta_ahora)-1:\n",
        "            r2,c2 = camino_hasta_ahora[i+1]\n",
        "\n",
        "            ax.arrow(c+0.5, N-1-r+0.5,\n",
        "                     c2-c, -(r2-r),\n",
        "                     head_width=0.2,\n",
        "                     length_includes_head=True,\n",
        "                     color='orange',\n",
        "                     linewidth=2)\n",
        "\n",
        "    # inicio\n",
        "    r,c = inicio\n",
        "    ax.add_patch(plt.Rectangle((c, N-1-r),1,1,color=\"red\"))\n",
        "    ax.text(c+0.5, N-1-r+0.5, \"A\",\n",
        "            ha='center', va='center',\n",
        "            color='white', fontsize=14)\n",
        "\n",
        "    # destino\n",
        "    r,c = objetivo\n",
        "    ax.add_patch(plt.Rectangle((c, N-1-r),1,1,color=\"green\"))\n",
        "    ax.text(c+0.5, N-1-r+0.5, \"B\",\n",
        "            ha='center', va='center',\n",
        "            color='white', fontsize=14)\n",
        "\n",
        "    ax.set_xlim(0,N)\n",
        "    ax.set_ylim(0,N)\n",
        "    ax.set_aspect('equal')\n",
        "    ax.axis('off')\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# =========================\n",
        "# ANIMACIÓN DEL RECORRIDO\n",
        "# =========================\n",
        "\n",
        "camino = a_star()\n",
        "\n",
        "print(\"🚗 Mostrando recorrido paso a paso...\")\n",
        "\n",
        "for i in range(1, len(camino)+1):\n",
        "    dibujar_parcial(camino[:i])\n",
        "    time.sleep(2)"
      ],
