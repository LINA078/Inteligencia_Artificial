      "cell_type": "code",
      "source": [
        "import networkx as nx\n",
        "import matplotlib.pyplot as plt\n",
        "from collections import deque\n",
        "import time\n",
        "import sys\n",
        "from IPython.display import clear_output\n",
        "\n",
        "\n",
        "# -------- GRAFO 1 (BFS) --------\n",
        "\n",
        "G1 = nx.Graph()\n",
        "\n",
        "edges1 = [\n",
        "    ('A','B'),('A','C'),\n",
        "    ('B','D'),('B','E'),\n",
        "    ('C','F')\n",
        "]\n",
        "\n",
        "G1.add_edges_from(edges1)\n",
        "\n",
        "pos1 = nx.spring_layout(G1)\n",
        "\n",
        "\n",
        "# -------- GRAFO 2 (DFS) --------\n",
        "\n",
        "G2 = nx.Graph()\n",
        "\n",
        "edges2 = [\n",
        "    ('A','B'),('A','C'),\n",
        "    ('C','D'),('D','E'),\n",
        "    ('E','F')\n",
        "]\n",
        "\n",
        "G2.add_edges_from(edges2)\n",
        "\n",
        "pos2 = nx.spring_layout(G2)\n",
        "\n",
        "\n",
        "paso = 0\n",
        "\n",
        "\n",
        "# -------- FUNCIÓN PARA DIBUJAR ANIMACIÓN --------\n",
        "\n",
        "def dibujar(G, pos, arbol, visitados, actual, tipo):\n",
        "\n",
        "    global paso\n",
        "    paso += 1\n",
        "\n",
        "    plt.figure(figsize=(6,6))\n",
        "\n",
        "    colores = []\n",
        "\n",
        "    for nodo in G.nodes():\n",
        "\n",
        "        if nodo == actual:\n",
        "            colores.append(\"#ff9ecb\")   # rosado\n",
        "\n",
        "        elif nodo in visitados:\n",
        "            colores.append(\"#90ee90\")   # verde claro\n",
        "\n",
        "        else:\n",
        "            colores.append(\"#d3d3d3\")   # gris\n",
        "\n",
        "\n",
        "    nx.draw(G,pos,with_labels=True,node_color=colores,node_size=1300)\n",
        "\n",
        "    nx.draw_networkx_edges(\n",
        "        G,\n",
        "        pos,\n",
        "        edgelist=arbol,\n",
        "        width=4,\n",
        "        edge_color=\"red\"\n",
        "    )\n",
        "\n",
        "    plt.title(f\"{tipo} - Paso {paso}\")\n",
        "\n",
        "    clear_output(wait=True)\n",
        "    plt.show()\n",
        "\n",
        "    time.sleep(2)\n",
        "\n",
        "\n",
        "# -------- BFS --------\n",
        "\n",
        "def bfs(G,pos,inicio):\n",
        "\n",
        "    global paso\n",
        "    paso = 0\n",
        "\n",
        "    cola = deque([inicio])\n",
        "    visitados = []\n",
        "    arbol = []\n",
        "\n",
        "    memoria = sys.getsizeof(cola)\n",
        "\n",
        "    while cola:\n",
        "\n",
        "        nodo = cola.popleft()\n",
        "\n",
        "        if nodo not in visitados:\n",
        "\n",
        "            visitados.append(nodo)\n",
        "\n",
        "            dibujar(G,pos,arbol,visitados,nodo,\"BFS\")\n",
        "\n",
        "            for vecino in G.neighbors(nodo):\n",
        "\n",
        "                if vecino not in visitados:\n",
        "\n",
        "                    cola.append(vecino)\n",
        "                    arbol.append((nodo,vecino))\n",
        "\n",
        "            memoria = max(memoria, sys.getsizeof(cola))\n",
        "\n",
        "    return memoria, arbol\n",
        "\n",
        "\n",
        "# -------- DFS --------\n",
        "\n",
        "def dfs(G,pos,inicio):\n",
        "\n",
        "    global paso\n",
        "    paso = 0\n",
        "\n",
        "    pila = [inicio]\n",
        "    visitados = []\n",
        "    arbol = []\n",
        "\n",
        "    memoria = sys.getsizeof(pila)\n",
        "\n",
        "    while pila:\n",
        "\n",
        "        nodo = pila.pop()\n",
        "\n",
        "        if nodo not in visitados:\n",
        "\n",
        "            visitados.append(nodo)\n",
        "\n",
        "            dibujar(G,pos,arbol,visitados,nodo,\"DFS\")\n",
        "\n",
        "            for vecino in G.neighbors(nodo):\n",
        "\n",
        "                if vecino not in visitados:\n",
        "\n",
        "                    pila.append(vecino)\n",
        "                    arbol.append((nodo,vecino))\n",
        "\n",
        "            memoria = max(memoria, sys.getsizeof(pila))\n",
        "\n",
        "    return memoria, arbol\n",
        "\n",
        "\n",
        "# -------- EJECUCIÓN --------\n",
        "\n",
        "print(\"RECORRIDO BFS EN GRAFO 1\")\n",
        "\n",
        "mem_bfs, arbol_bfs = bfs(G1,pos1,'A')\n",
        "\n",
        "time.sleep(2)\n",
        "\n",
        "print(\"RECORRIDO DFS EN GRAFO 2\")\n",
        "\n",
        "mem_dfs, arbol_dfs = dfs(G2,pos2,'A')\n",
        "\n",
        "\n",
        "# -------- COMPARACIÓN --------\n",
        "\n",
        "print(\"\\nCOMPARACIÓN FINAL\")\n",
        "\n",
        "print(\"Memoria BFS:\",mem_bfs,\"bytes\")\n",
        "print(\"Memoria DFS:\",mem_dfs,\"bytes\")\n",
        "\n",
        "\n",
        "# -------- MOSTRAR LOS DOS GRAFOS FINALES --------\n",
        "\n",
        "plt.figure(figsize=(12,5))\n",
        "\n",
        "\n",
        "# Grafo BFS final\n",
        "\n",
        "plt.subplot(1,2,1)\n",
        "\n",
        "nx.draw(G1,pos1,with_labels=True,node_size=1300)\n",
        "\n",
        "nx.draw_networkx_edges(\n",
        "    G1,\n",
        "    pos1,\n",
        "    edgelist=arbol_bfs,\n",
        "    width=4,\n",
        "    edge_color=\"red\"\n",
        ")\n",
        "\n",
        "plt.title(\"Recorrido Final BFS\")\n",
        "\n",
        "\n",
        "# Grafo DFS final\n",
        "\n",
        "plt.subplot(1,2,2)\n",
        "\n",
        "nx.draw(G2,pos2,with_labels=True,node_size=1300)\n",
        "\n",
        "nx.draw_networkx_edges(\n",
        "    G2,\n",
        "    pos2,\n",
        "    edgelist=arbol_dfs,\n",
        "    width=4,\n",
        "    edge_color=\"red\"\n",
        ")\n",
        "\n",
        "plt.title(\"Recorrido Final DFS\")\n",
        "\n",
        "plt.show()"
      ],
