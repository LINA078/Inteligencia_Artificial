import random
opciones = ["piedra", "papel", "tijera"]
def ganador(jugador, computadora):

    if jugador == computadora:
        return "Empate 😐"

    if (jugador == "piedra" and computadora == "tijera") or \
       (jugador == "papel" and computadora == "piedra") or \
       (jugador == "tijera" and computadora == "papel"):
        return "Ganaste 🎉"

    return "Perdiste 😢"

print("🎮 PIEDRA - PAPEL - TIJERA")
print("Escribe: piedra, papel o tijera")
print("Escribe 'salir' para terminar\n")

while True:

    jugador = input("Tu elección: ").lower()

    if jugador == "salir":
        print("👋 Gracias por jugar")
        break

    if jugador not in opciones:
        print("⚠️ Opción inválida\n")
        continue

    computadora = random.choice(opciones)

    print(f"🤖 Computadora eligió: {computadora}")

    resultado = ganador(jugador, computadora)

    print(f"🏆 Resultado: {resultado}\n")
