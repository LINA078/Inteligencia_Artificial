      "source": [
        "import random\n",
        "opciones = [\"piedra\", \"papel\", \"tijera\"]\n",
        "def ganador(jugador, computadora):\n",
        "\n",
        "    if jugador == computadora:\n",
        "        return \"Empate 😐\"\n",
        "\n",
        "    if (jugador == \"piedra\" and computadora == \"tijera\") or \\\n",
        "       (jugador == \"papel\" and computadora == \"piedra\") or \\\n",
        "       (jugador == \"tijera\" and computadora == \"papel\"):\n",
        "        return \"Ganaste 🎉\"\n",
        "\n",
        "    return \"Perdiste 😢\"\n",
        "\n",
        "print(\"🎮 PIEDRA - PAPEL - TIJERA\")\n",
        "print(\"Escribe: piedra, papel o tijera\")\n",
        "print(\"Escribe 'salir' para terminar\\n\")\n",
        "\n",
        "while True:\n",
        "\n",
        "    jugador = input(\"Tu elección: \").lower()\n",
        "\n",
        "    if jugador == \"salir\":\n",
        "        print(\"👋 Gracias por jugar\")\n",
        "        break\n",
        "\n",
        "    if jugador not in opciones:\n",
        "        print(\"⚠️ Opción inválida\\n\")\n",
        "        continue\n",
        "\n",
        "    computadora = random.choice(opciones)\n",
        "\n",
        "    print(f\"🤖 Computadora eligió: {computadora}\")\n",
        "\n",
        "    resultado = ganador(jugador, computadora)\n",
        "\n",
        "    print(f\"🏆 Resultado: {resultado}\\n\")"
      ]
